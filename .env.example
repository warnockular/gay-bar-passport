# Copy this file to .env.local for local development.
# Public values are safe for the browser because Supabase anon keys are protected by Row Level Security in later phases.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Google Places key for admin import previews. Never prefix this with NEXT_PUBLIC.
GOOGLE_PLACES_API_KEY=

# App metadata used by auth redirects in local, Vercel preview, and production deployments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
